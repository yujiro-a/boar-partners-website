<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Color Flow — BOAR Partners TOP</title>
  <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@700;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #060809; font-family: 'Hiragino Sans W3', sans-serif; -webkit-font-smoothing: antialiased; }
    .acc { font-family: 'Big Shoulders Display', sans-serif; }
    .dp  { font-family: 'Hiragino Sans W6', sans-serif; }
    .label { font-size:11px; letter-spacing:0.22em; text-transform:uppercase; font-weight:700; margin-bottom:12px; }
    .h2   { font-size:clamp(24px,3.5vw,44px); font-weight:900; line-height:1.1; margin-bottom:16px; }
    .body { font-size:14px; line-height:1.9; max-width:520px; }
    .tag  { display:inline-block; font-size:11px; letter-spacing:0.1em; font-weight:900; padding:3px 12px; }

    /* 共通レイアウト */
    .section { padding: 64px 40px; }
    .section-sm { padding: 48px 40px; }
    .inner { max-width: 800px; margin: 0 auto; }

    /* ページタイトル */
    .page-header {
      background: #0d1a14;
      padding: 28px 40px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      position: sticky; top: 0; z-index: 50;
    }

    /* パターンラベル */
    .pattern-header {
      background: #0a1208;
      padding: 18px 40px;
      display: flex; align-items: center; gap: 16px;
      border-top: 3px solid var(--accent);
    }

    /* 色サンプルチップ */
    .chip { width:14px; height:14px; border-radius:2px; display:inline-block; }

    /* 暗→暗の繋ぎ（前後の文脈として表示） */
    .dark-bridge {
      background: linear-gradient(180deg, #0d1a14 0%, #152f26 100%);
      padding: 32px 40px;
      display: flex; align-items: center; gap: 12px;
    }
    .dark-marker {
      font-size:11px; color:rgba(255,255,255,0.2); letter-spacing:0.15em;
      text-transform:uppercase;
    }

    /* フッター遷移 */
    .footer-section {
      padding: 40px 40px 32px;
      display: flex; justify-content: center; align-items: center;
      font-size: 12px; letter-spacing:0.04em;
    }

    /* 評価バー */
    .verdict {
      background: rgba(255,255,255,0.03);
      border-top: 1px solid rgba(255,255,255,0.06);
      padding: 14px 40px;
      display: grid; grid-template-columns: 80px 1fr; gap: 16px; align-items: center;
    }

    @media (max-width: 600px) {
      .section { padding: 48px 24px; }
      .section-sm { padding: 36px 24px; }
      .dark-bridge { padding: 24px 24px; }
      .pattern-header { padding: 16px 24px; }
      .verdict { padding: 12px 24px; }
    }
  </style>
</head>
<body>

<div class="page-header">
  <div class="label acc" style="color:rgba(255,255,255,0.3);">TOP PAGE — Color Flow Study</div>
  <div class="acc" style="color:#fff; font-size:20px; font-weight:900; margin-bottom:6px;">Services以降の色の流れ — 5パターン</div>
  <div style="color:rgba(255,255,255,0.35); font-size:13px;">
    暗（WhatWeAre）→ <strong style="color:rgba(255,255,255,0.7);">Services（明転ポイント）</strong>→ Contact → Footer の色遷移比較
  </div>
</div>


