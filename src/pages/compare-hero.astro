<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>BOAR — Hero Subtitle Patterns</title>
  <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@700;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #020908; -webkit-font-smoothing: antialiased; }
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      background: rgba(2,9,8,0.97); backdrop-filter: blur(8px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      padding: 8px 24px; display: flex; gap: 4px; align-items: center; flex-wrap: wrap;
    }
    .nav a {
      font-family: 'Big Shoulders Display', sans-serif;
      font-size: 11px; font-weight: 700; letter-spacing: 0.12em;
      text-transform: uppercase; text-decoration: none;
      color: rgba(255,255,255,0.3); padding: 4px 8px;
      border: 1px solid transparent; transition: color 0.2s;
    }
    .nav a:hover { color: #fff; border-color: rgba(255,255,255,0.1); }
    .nav .back { color: rgba(255,255,255,0.18); font-size: 10px; border: none; margin-right: 8px; }
    .nav .grp {
      font-family: 'Big Shoulders Display', sans-serif;
      font-size: 10px; letter-spacing: .14em; color: rgba(255,255,255,.18);
      padding: 0 6px; margin-left: 6px;
    }
    body > div { margin-top: 40px; }

    .hero {
      min-height: 100vh;
      background: linear-gradient(160deg, #152f26 0%, #090c0e 100%);
      display: flex; flex-direction: column;
      justify-content: center; align-items: center;
      position: relative; overflow: hidden; padding: 40px 32px;
    }

    /* grid */
    .hero-grid {
      position: absolute; inset: -100px 0 0 0; overflow: hidden; pointer-events: none;
    }
    .hero-grid svg { width: 100%; height: calc(100% + 100px); opacity: 0.06; animation: gridDrift 8s linear infinite; }

    /* fade right-bottom */
    .hero-fade { position: absolute; inset: 0; background: radial-gradient(ellipse 80% 80% at 100% 100%, rgba(9,12,14,0.95) 0%, transparent 60%); pointer-events: none; }

    .hero-inner { position: relative; z-index: 1; max-width: 1200px; text-align: center; }

    .hero-title {
      font-family: 'Big Shoulders Display', sans-serif;
      font-size: clamp(64px, 11vw, 160px); font-weight: 900;
      color: #fff; letter-spacing: 0.04em; line-height: 1.05;
      margin-bottom: 32px;
    }

    .hero-sub {
      font-family: 'Big Shoulders Display', sans-serif;
      font-size: clamp(16px, 2.2vw, 26px); font-weight: 700;
      letter-spacing: 0.18em; text-transform: uppercase;
      color: rgba(255,255,255,0.6); margin-bottom: 56px;
    }

    .hero-btn {
      display: inline-block; padding: 18px 48px;
      border: 1px solid rgba(255,255,255,0.5); color: #fff;
      text-decoration: none;
      font-family: 'Big Shoulders Display', sans-serif;
      font-size: 16px; letter-spacing: 0.15em; text-transform: uppercase; font-weight: 700;
    }

    .label {
      position: absolute; top: 16px; left: 32px; z-index: 10;
      font-family: 'Big Shoulders Display', sans-serif;
      font-size: 10px; font-weight: 700; letter-spacing: 0.2em;
      color: rgba(255,255,255,0.15); text-transform: uppercase;
    }
    .label span { color: rgba(255,255,255,0.4); margin-left: 8px; font-size: 11px; }

    hr.div { border: none; border-top: 3px solid rgba(255,255,255,0.06); }

    @keyframes gridDrift {
      0%   { transform: translateY(0); }
      100% { transform: translateY(-100px); }
    }
  </style>
</head>
