---
import AboutPage from "../components/AboutPage.jsx";
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>About — BOAR Partners</title>
    <meta name="description" content="BOAR Partnersのチームと会社概要。実行する者が、伴走する。" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@700;800;900&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html { scroll-behavior: auto; }
      body {
        background: #090c0e;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      @media (max-width: 768px) {
        .desktop-nav { display: none !important; }
        .mobile-menu-btn { display: block !important; }
      }
      @media (min-width: 769px) {
        .mobile-menu-btn { display: none !important; }
      }
    </style>
  </head>
  <body>
    <AboutPage client:load />
    <script>
      function scrollToHash(hash, instant) {
        if (!hash) return;
        const el = document.querySelector(hash);
        if (!el) return;
        el.scrollIntoView({ behavior: instant ? 'instant' : 'smooth', block: 'center' });
      }

      // 初回ロード: デフォルトスクロールをリセットしてから中央へ
      window.addEventListener('load', () => {
        const hash = window.location.hash;
        if (!hash) return;
        window.scrollTo(0, 0);
        setTimeout(() => scrollToHash(hash, false), 80);
      });

      // 戻る/進む操作
      window.addEventListener('popstate', () => {
        scrollToHash(window.location.hash, false);
      });
    </script>
  </body>
</html>
