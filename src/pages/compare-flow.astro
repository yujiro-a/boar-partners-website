<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>BOAR — Section Flow Patterns</title>
  <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@700;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #020908; -webkit-font-smoothing: antialiased; font-family: 'Hiragino Sans W3', sans-serif; }
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      background: rgba(2,9,8,0.97); backdrop-filter: blur(8px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      padding: 8px 24px; display: flex; gap: 4px; align-items: center; flex-wrap: wrap;
    }
    .nav a {
      font-family: 'Big Shoulders Display', sans-serif; font-size: 11px; font-weight: 700;
      letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none;
      color: rgba(255,255,255,0.3); padding: 4px 8px; border: 1px solid transparent;
    }
    .nav a:hover { color: #fff; border-color: rgba(255,255,255,0.1); }
    .nav .back { color: rgba(255,255,255,0.18); font-size: 10px; border: none; margin-right: 8px; }
    .nav .grp { font-family: 'Big Shoulders Display', sans-serif; font-size: 10px; letter-spacing: .14em; color: rgba(255,255,255,.18); padding: 0 4px; margin-left: 4px; }
    body > div { margin-top: 40px; }

    /* ── Section block ── */
    .sec {
      padding: 72px 48px; position: relative;
      display: flex; flex-direction: column; justify-content: center;
      min-height: 260px;
    }
    .sec-label {
      font-family: 'Big Shoulders Display', sans-serif; font-size: 10px; font-weight: 700;
      letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 14px;
    }
    .sec-title { font-family: 'Big Shoulders Display', sans-serif; font-size: clamp(28px,4vw,52px); font-weight: 900; line-height: 1.1; margin-bottom: 12px; }
    .sec-body { font-size: 14px; line-height: 1.8; max-width: 560px; }
    .sec-tag {
      position: absolute; top: 20px; right: 24px;
      font-family: 'Big Shoulders Display', sans-serif; font-size: 10px; letter-spacing: .18em;
      text-transform: uppercase; opacity: .25;
    }

    /* ── Pattern label ── */
    .pattern-label {
      padding: 20px 48px; border-bottom: 1px solid rgba(255,255,255,0.06);
      font-family: 'Big Shoulders Display', sans-serif; font-size: 12px; font-weight: 700;
      letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.22);
      background: #020908;
    }
    .pattern-label span { color: rgba(255,255,255,0.5); margin-left: 10px; font-size: 13px; }

    hr.div { border: none; border-top: 4px solid rgba(255,255,255,0.04); }
  </style>
</head>
