      <div class="inner">
        <div class="ghost" style="letter-spacing:0.2em">BOAR</div>
        <div class="boar-list">
          <div class="boar-row"><span class="boar-initial">B</span><span class="boar-rest">uild the Business</span><span class="boar-ja">事業を構築する</span></div>
          <div class="boar-row"><span class="boar-initial">O</span><span class="boar-rest">pen Opportunities</span><span class="boar-ja">機会を開く</span></div>
          <div class="boar-row"><span class="boar-initial">A</span><span class="boar-rest">ccelerate Growth</span><span class="boar-ja">成長を加速する</span></div>
